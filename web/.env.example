# Copy to .env.local and fill in.
# Local Supabase stack values come from `supabase start`; hosted values from
# Supabase Dashboard -> Project Settings -> API.

# Public (client-exposed): the project URL and the publishable (anon) key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only: the secret (service_role) key. NEVER expose to the client or
# import into any file under src/. Used only by supabase/ scripts/migrations.
SUPABASE_SECRET_KEY=
